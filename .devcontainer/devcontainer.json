{
  "build": {
		"dockerfile": "Dockerfile",
		"context": "."
  },
  "forwardPorts": [3005, 8080],
  "portsAttributes": {
    "3005": {
      "label": "Vite"
    },
    "8080": {
      "label": "SQLite GUI"
    }
  },
  "containerEnv": {
    "DATABASE_URL": "file:/workspace/data/db.sqlite"
  },
  "postCreateCommand": "pnpm install"
}

